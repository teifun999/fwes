<Window x:Class="RemoteControlServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteEmuControl Server" Height="720" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- Top: pairing info -->
        <Border Grid.Row="0" BorderBrush="#DDDDDD" BorderThickness="1" Padding="12" Margin="0,0,0,12" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="QrImage" Grid.Column="0" Width="150" Height="150" Margin="0,0,20,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Mit RemoteEmuControl-iOS-App scannen oder manuell eingeben:"
                               FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="PIN: " FontSize="14"/>
                        <TextBlock x:Name="PinText" FontSize="20" FontWeight="Bold" Foreground="#2563EB"/>
                    </StackPanel>
                    <TextBlock x:Name="IpText" FontSize="12" Foreground="Gray" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RegenerateButton" Content="PIN neu generieren" Padding="8,4" Margin="0,0,8,0" Click="RegenerateButton_Click"/>
                        <Button x:Name="RefreshEmulatorsButton" Content="Emulatoren neu suchen" Padding="8,4" Click="RefreshEmulatorsButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Middle: emulator list -->
        <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" Padding="8" Margin="0,0,0,12" CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Erkannte Emulatoren" FontWeight="Bold" Margin="4,0,0,8"/>
                <ListView x:Name="EmulatorListView">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="160" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Typ" Width="110" DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="Status" Width="90" DisplayMemberBinding="{Binding Status}"/>
                            <GridViewColumn Header="ADB" Width="140" DisplayMemberBinding="{Binding AdbSerial}"/>
                            <GridViewColumn Header="Aktiv" Width="60" DisplayMemberBinding="{Binding IsActive}"/>
                            <GridViewColumn Header="Aktionen" Width="260">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Start" Padding="6,2" Margin="0,0,4,0" Click="StartEmulator_Click" Tag="{Binding}"/>
                                            <Button Content="Stop" Padding="6,2" Margin="0,0,4,0" Click="StopEmulator_Click" Tag="{Binding}"/>
                                            <Button Content="Neustart" Padding="6,2" Margin="0,0,4,0" Click="RestartEmulator_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- Bottom: embedded debug log (this replaces the separate cmd window) -->
        <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="1" Padding="8" CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Debug-Log" FontWeight="Bold" Margin="4,0,0,8"/>
                <TextBox x:Name="LogBox"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         Background="#111318" Foreground="#D6D6D6"
                         TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
